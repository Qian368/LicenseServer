{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-caller",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/许可证验证调用示例/许可证验证调用示例.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-server",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/LicenseServer.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}